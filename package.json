{
  "name": "@react-hive/honey-style",
  "version": "5.3.0",
  "description": "",
  "keywords": [
    "react",
    "styled-components",
    "typescript"
  ],
  "homepage": "https://github.com/React-Hive/honey-style",
  "bugs": {
    "url": "https://github.com/React-Hive/honey-style/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/React-Hive/honey-style.git"
  },
  "author": "Mike Aliinyk <m.aliynik@gmail.com>",
  "license": "MIT",
  "scripts": {
    "prepare": "husky",
    "clean": "rm -rf dist coverage",
    "build": "webpack --config webpack.config.mjs",
    "test": "vitest",
    "prepublishOnly": "CI=1 pnpm clean && pnpm test && pnpm build",
    "performanceTest": "jest --testMatch **/*.performance.spec.tsx --testPathIgnorePatterns=''",
    "diagnostics": "tsx scripts/collect-diagnostics.ts"
  },
  "type": "module",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "default": "./dist/index.mjs"
    }
  },
  "files": [
    "dist",
    "!dist/**/__mocks__",
    "!dist/**/__tests__"
  ],
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "styled-components": "^6.1.0"
  },
  "dependencies": {
    "@react-hive/honey-css": "1.17.0",
    "@react-hive/honey-utils": "3.28.0",
    "csstype": "3.2.3"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "22.19.15",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "copy-webpack-plugin": "14.0.0",
    "eslint": "10.1.0",
    "eslint-plugin-react": "7.37.5",
    "html-webpack-plugin": "5.6.6",
    "husky": "9.1.7",
    "jsdom": "29.0.1",
    "prettier": "3.8.1",
    "ts-loader": "9.5.4",
    "tsx": "4.21.0",
    "typescript": "6.0.2",
    "typescript-eslint": "8.57.2",
    "vitest": "4.1.2",
    "webpack": "5.105.4",
    "webpack-cli": "7.0.2"
  },
  "browserslist": [
    "defaults",
    "not IE 11"
  ]
}
