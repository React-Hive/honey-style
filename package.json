{
  "name": "@react-hive/honey-style",
  "version": "5.2.0",
  "description": "",
  "keywords": [
    "react",
    "styled-components",
    "typescript"
  ],
  "homepage": "https://github.com/React-Hive/honey-style",
  "bugs": {
    "url": "https://github.com/React-Hive/honey-style/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/React-Hive/honey-style.git"
  },
  "author": "Mike Aliinyk <m.aliynik@gmail.com>",
  "license": "MIT",
  "scripts": {
    "prepare": "husky",
    "clean": "rm -rf dist coverage",
    "build": "webpack --config webpack.config.mjs",
    "test": "jest --coverage",
    "prepublishOnly": "pnpm clean && pnpm test && pnpm build",
    "performanceTest": "jest --testMatch **/*.performance.spec.tsx --testPathIgnorePatterns=''",
    "diagnostics": "tsx scripts/collect-diagnostics.ts"
  },
  "type": "module",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "default": "./dist/index.mjs"
    }
  },
  "files": [
    "dist",
    "!dist/**/__mocks__",
    "!dist/**/__tests__",
    "!dist/**/jest*"
  ],
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "styled-components": "^6.1.0"
  },
  "dependencies": {
    "@mdx-js/react": "3.1.1",
    "@react-hive/honey-css": "1.16.0",
    "@react-hive/honey-utils": "3.27.0",
    "csstype": "3.2.3"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@mdx-js/loader": "3.1.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/jest": "29.5.14",
    "@types/mdx": "2.0.13",
    "@types/node": "22.19.15",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "copy-webpack-plugin": "14.0.0",
    "eslint": "10.1.0",
    "eslint-plugin-react": "7.37.5",
    "html-webpack-plugin": "5.6.6",
    "husky": "9.1.7",
    "jest": "29.7.0",
    "jest-environment-jsdom": "29.7.0",
    "prettier": "3.8.1",
    "ts-jest": "29.4.5",
    "ts-loader": "9.5.4",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.57.2",
    "webpack": "5.105.4",
    "webpack-cli": "7.0.2"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "jsdom",
    "setupFilesAfterEnv": [
      "<rootDir>/jest-setup.ts"
    ],
    "testMatch": [
      "**/src/**/__tests__/**/*.spec.ts?(x)"
    ],
    "testPathIgnorePatterns": [
      "\\.performance\\.spec\\.tsx$"
    ]
  },
  "browserslist": [
    "defaults",
    "not IE 11"
  ]
}
